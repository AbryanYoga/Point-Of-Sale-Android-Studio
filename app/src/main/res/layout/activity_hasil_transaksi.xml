<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Transaksi.HasilTransaksiActivity"
    android:background="@color/bgScreen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- RECEIPT STRUK CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStruk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bgCard"
                app:strokeWidth="1dp"
                app:strokeColor="@color/strokeCard"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <ImageView
                        android:id="@+id/imgLogo"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/logo"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- STORE NAME -->
                    <TextView
                        android:id="@+id/tvStrukToko"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Point Of Sales"
                        android:textColor="@color/textPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgLogo" />

                    <!-- BRANCH SUBHEADER -->
                    <TextView
                        android:id="@+id/tvNamaCabang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cabang"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvStrukToko" />

                    <!-- BRANCH ADDRESS -->
                    <TextView
                        android:id="@+id/tvAlamatToko"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Alamat Cabang"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNamaCabang" />

                    <TextView
                        android:id="@+id/separator1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/tvAlamatToko" />

                    <!-- ID TRANSAKSI -->
                    <TextView
                        android:id="@+id/tvLabelIdTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="ID Transaksi"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/separator1" />

                    <TextView
                        android:id="@+id/tvIdTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#TRX-00000000"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelIdTransaksi" />

                    <!-- TANGGAL WAKTU -->
                    <TextView
                        android:id="@+id/tvLabelTanggal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tanggal &amp; Waktu"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelIdTransaksi" />

                    <TextView
                        android:id="@+id/tvStrukTanggalWaktu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelTanggal" />

                    <!-- KASIR -->
                    <TextView
                        android:id="@+id/tvLabelKasir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Kasir Bertugas"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelTanggal" />

                    <TextView
                        android:id="@+id/tvNamaKasir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelKasir" />

                    <!-- HP KASIR -->
                    <TextView
                        android:id="@+id/tvLabelHpKasir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Nomor HP Kasir"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelKasir" />

                    <TextView
                        android:id="@+id/tvHpKasir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelHpKasir" />

                    <TextView
                        android:id="@+id/separator2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelHpKasir" />

                    <!-- RECIPES ITEMS -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvStrukItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/separator2"
                        tools:listitem="@layout/item_struk_produk" />

                    <TextView
                        android:id="@+id/separator3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/rvStrukItems" />

                    <!-- TOTALS -->
                    <TextView
                        android:id="@+id/tvLabelSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Subtotal"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/separator3" />

                    <TextView
                        android:id="@+id/tvStrukSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelSubtotal" />

                    <TextView
                        android:id="@+id/tvLabelPpn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="PPN (11%)"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelSubtotal" />

                    <TextView
                        android:id="@+id/tvStrukPpn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelPpn" />

                    <TextView
                        android:id="@+id/tvLabelTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Total"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelPpn" />

                    <TextView
                        android:id="@+id/tvStrukTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelTotal" />

                    <TextView
                        android:id="@+id/tvLabelBayar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Nominal Bayar"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelTotal" />

                    <TextView
                        android:id="@+id/tvStrukBayar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelBayar" />

                    <TextView
                        android:id="@+id/tvLabelKembalian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Kembalian"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelBayar" />

                    <TextView
                        android:id="@+id/tvStrukKembalian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#4CAF50"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvLabelKembalian" />

                    <TextView
                        android:id="@+id/separator4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelKembalian" />

                    <!-- FOOTER -->
                    <TextView
                        android:id="@+id/tvStrukFooter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Terima kasih telah berbelanja di Point Of Sales!\nSampai jumpa kembali 😊"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/separator4" />

                    <TextView
                        android:id="@+id/tvStrukContact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Contact: -"
                        android:textColor="@color/textHint"
                        android:textSize="11sp"
                        app:layout_constraintTop_toBottomOf="@id/tvStrukFooter" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PRINT AND NAVIGATION BUTTONS -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardBottomControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardStruk"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <Button
                    android:id="@+id/btnPrint"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_btn_proses"
                    app:backgroundTint="@null"
                    android:text="Print Struk"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <Button
                    android:id="@+id/btnTransaksiBaru"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_btn_secondary"
                    app:backgroundTint="@null"
                    android:text="Transaksi Baru"
                    android:textColor="@color/accentPurple"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/btnPrint"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
