<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".Cabang.ModCabangActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:backgroundTint="?attr/colorSurfaceVariant"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="40dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="?attr/colorSurface"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="21dp"
                    app:cardElevation="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imageBack"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/back"
                        app:tint="?attr/colorOnSurface" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvTambahCabang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="28dp"
                    android:letterSpacing="-0.02"
                    android:text="Data Cabang"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardBack" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDalam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginEnd="20dp"
                    android:backgroundTint="?attr/colorSurface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTambahCabang">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/labelNama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="NAMA CABANG"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <EditText
                            android:id="@+id/etNamaCabang"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Masukkan nama cabang"
                            android:inputType="text"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelNama" />

                        <TextView
                            android:id="@+id/labelKode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="KODE CABANG"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etNamaCabang" />

                        <EditText
                            android:id="@+id/etKodeCabang"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Masukkan kode cabang"
                            android:inputType="text"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelKode" />

                        <TextView
                            android:id="@+id/labelPJ"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="PENANGGUNG JAWAB"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etKodeCabang" />

                        <EditText
                            android:id="@+id/etPenanggungJawab"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Masukkan penanggung jawab"
                            android:inputType="text"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelPJ" />

                        <TextView
                            android:id="@+id/labelNomor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="NOMOR CABANG"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etPenanggungJawab" />

                        <EditText
                            android:id="@+id/etNomorCabang"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Masukkan nomor cabang"
                            android:inputType="phone"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelNomor" />

                        <TextView
                            android:id="@+id/labelAlamat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="ALAMAT CABANG"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etNomorCabang" />

                        <EditText
                            android:id="@+id/etAlamatCabang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="100dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Masukkan alamat cabang"
                            android:inputType="textMultiLine"
                            android:gravity="top|start"
                            android:padding="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelAlamat" />

                        <TextView
                            android:id="@+id/labelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="STATUS"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etAlamatCabang" />

                        <Spinner
                            android:id="@+id/spinnerStatus"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:paddingHorizontal="20dp"
                            app:layout_constraintTop_toBottomOf="@id/labelStatus" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnSimpan"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="#4F46E5"
                    android:letterSpacing="0.02"
                    android:text="Simpan Data"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardDalam" />

                <Button
                    android:id="@+id/btnHapus"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#FEE2E2"
                    android:letterSpacing="0.02"
                    android:text="Hapus Data"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSimpan" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
