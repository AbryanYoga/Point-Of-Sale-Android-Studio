<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/Kembali"
    tools:context=".Produk.ModProduk">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:backgroundTint="@color/backgroundModKategori"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="40dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="40dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/Kembali"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="21dp"
                    app:cardElevation="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imageBack"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/back"
                        app:tint="@color/icon" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvTambahProduk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="28dp"
                    android:letterSpacing="-0.02"
                    android:text="Data Produk"
                    android:textColor="@color/textModkategori"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardBack" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDalam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginEnd="20dp"
                    android:backgroundTint="@color/CardDalam"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTambahProduk">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/labelNama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="NAMA PRODUK"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <EditText
                            android:id="@+id/etNamaKategori"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="@color/FieldEdit"
                            android:hint="Masukkan nama produk"
                            android:inputType="text"
                            android:paddingHorizontal="20dp"
                            android:textColor="@color/textModkategori"
                            android:textColorHint="@color/textHint"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelNama" />

                        <TextView
                            android:id="@+id/labelImageUrl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="GAMBAR PRODUK (URL)"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etNamaKategori" />

                        <EditText
                            android:id="@+id/etImageUrl"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="@color/FieldEdit"
                            android:hint="Masukkan URL gambar"
                            android:inputType="textUri"
                            android:padding="14dp"
                            android:textColor="@color/textModkategori"
                            android:textColorHint="@color/textHint"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelImageUrl" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardImageGuide"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:cardBackgroundColor="#FFFBEB"
                            app:layout_constraintTop_toBottomOf="@id/etImageUrl">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="12dp"
                                android:textColor="#374151"
                                android:textSize="12sp"
                                android:lineSpacingMultiplier="1.2"
                                android:text="⚠️ Ketentuan URL Gambar:\n• Gunakan URL yang diakhiri .jpg / .png / .jpeg / .webp\n• Rekomendasi: upload ke imgur.com lalu copy Direct Link\n• Contoh format: https://i.imgur.com/abc123.jpg\n• Jangan gunakan link Google Drive biasa\n• Jangan gunakan link hasil screenshot Google Images\n• Pastikan link bisa dibuka langsung di browser" />
                        </com.google.android.material.card.MaterialCardView>

                        <Button
                            android:id="@+id/btnPreviewGambar"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#0F3460"
                            android:text="Preview Gambar"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:cornerRadius="12dp"
                            app:layout_constraintTop_toBottomOf="@id/cardImageGuide" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardPreview"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#0F3460"
                            app:layout_constraintTop_toBottomOf="@id/btnPreviewGambar">

                            <ImageView
                                android:id="@+id/imgPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/labelHarga"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HARGA PRODUK"
                            android:letterSpacing="0.05"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:layout_marginTop="20dp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/cardPreview" />

                        <EditText
                            android:id="@+id/etHargaProduk"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="@color/FieldEdit"
                            android:hint="Rp 0"
                            android:inputType="phone"
                            android:paddingHorizontal="20dp"
                            android:textColor="@color/textModkategori"
                            android:textColorHint="@color/textHint"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelHarga" />

                        <TextView
                            android:id="@+id/labelJenis"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KATEGORI PRODUK"
                            android:letterSpacing="0.05"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:layout_marginTop="20dp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etHargaProduk" />

                        <HorizontalScrollView
                            android:id="@+id/scrollJenis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:scrollbars="none"
                            app:layout_constraintTop_toBottomOf="@id/labelJenis">

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/cgKategori"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleLine="true"
                                app:singleSelection="true"
                                app:selectionRequired="true" />
                        </HorizontalScrollView>

                        <TextView
                            android:id="@+id/tvEmptyKategori"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Belum ada data, tambahkan dulu di menu Kategori/Cabang"
                            android:textColor="#EF4444"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:layout_constraintTop_toBottomOf="@id/labelJenis" />

                        <TextView
                            android:id="@+id/labelStock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STOK"
                            android:letterSpacing="0.05"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:layout_marginTop="20dp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/scrollJenis" />

                        <EditText
                            android:id="@+id/etStock"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="@color/FieldEdit"
                            android:hint="0"
                            android:inputType="number"
                            android:paddingHorizontal="20dp"
                            android:textColor="@color/textModkategori"
                            android:textColorHint="@color/textHint"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelStock" />

                        <TextView
                            android:id="@+id/labelCabang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="CABANG"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etStock" />

                        <HorizontalScrollView
                            android:id="@+id/scrollCabang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:scrollbars="none"
                            app:layout_constraintTop_toBottomOf="@id/labelCabang">

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/cgCabang"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleLine="true"
                                app:singleSelection="true"
                                app:selectionRequired="true" />
                        </HorizontalScrollView>

                        <TextView
                            android:id="@+id/tvEmptyCabang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Belum ada data, tambahkan dulu di menu Kategori/Cabang"
                            android:textColor="#EF4444"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:layout_constraintTop_toBottomOf="@id/labelCabang" />

                        <TextView
                            android:id="@+id/labelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="STATUS"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/scrollCabang" />

                        <Spinner
                            android:id="@+id/spinnerStatus"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="@color/FieldEdit"
                            android:paddingHorizontal="20dp"
                            app:layout_constraintTop_toBottomOf="@id/labelStatus" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnSimpan"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginEnd="20dp"
                    android:backgroundTint="#4F46E5"
                    android:letterSpacing="0.02"
                    android:text="Simpan Data"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardDalam" />

                <Button
                    android:id="@+id/btnHapus"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#FEE2E2"
                    android:letterSpacing="0.02"
                    android:text="Hapus Data"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSimpan" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>