<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".Produk.ModProduk">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:backgroundTint="?attr/colorSurfaceVariant"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="40dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="40dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="?attr/colorSurface"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="21dp"
                    app:cardElevation="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imageBack"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/back"
                        app:tint="?attr/colorOnSurface" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvTambahProduk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="28dp"
                    android:letterSpacing="-0.02"
                    android:text="Data Produk"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardBack" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDalam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginEnd="20dp"
                    android:backgroundTint="?attr/colorSurface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTambahProduk">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/labelNama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="NAMA PRODUK"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <EditText
                            android:id="@+id/etNamaKategori"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Masukkan nama produk"
                            android:inputType="text"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelNama" />

                        <TextView
                            android:id="@+id/labelHarga"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HARGA PRODUK"
                            android:letterSpacing="0.05"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:layout_marginTop="20dp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etNamaKategori" />

                        <EditText
                            android:id="@+id/etHargaProduk"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="Rp 0"
                            android:inputType="phone"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelHarga" />

                        <TextView
                            android:id="@+id/labelJenis"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JENIS PRODUK"
                            android:letterSpacing="0.05"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:layout_marginTop="20dp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etHargaProduk" />

                        <Spinner
                            android:id="@+id/spinnerJenis"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:entries="@array/SpinnerJenisProduk"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:paddingHorizontal="20dp"
                            app:layout_constraintTop_toBottomOf="@id/labelJenis" />

                        <TextView
                            android:id="@+id/labelStock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STOK"
                            android:letterSpacing="0.05"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:layout_marginTop="20dp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/spinnerJenis" />

                        <EditText
                            android:id="@+id/etStock"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:hint="0"
                            android:inputType="number"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/labelStock" />

                        <TextView
                            android:id="@+id/labelCabang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="CABANG"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/etStock" />

                        <Spinner
                            android:id="@+id/spinnerCabang"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:entries="@array/SpinnerCabang"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:paddingHorizontal="20dp"
                            app:layout_constraintTop_toBottomOf="@id/labelCabang" />

                        <TextView
                            android:id="@+id/labelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.05"
                            android:text="STATUS"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/spinnerCabang" />

                        <Spinner
                            android:id="@+id/spinnerStatus"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_edittext"
                            android:backgroundTint="?attr/colorSurfaceVariant"
                            android:paddingHorizontal="20dp"
                            app:layout_constraintTop_toBottomOf="@id/labelStatus" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnSimpan"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginEnd="20dp"
                    android:backgroundTint="#4F46E5"
                    android:letterSpacing="0.02"
                    android:text="Simpan Data"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardDalam" />

                <Button
                    android:id="@+id/btnHapus"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#FEE2E2"
                    android:letterSpacing="0.02"
                    android:text="Hapus Data"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSimpan" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>