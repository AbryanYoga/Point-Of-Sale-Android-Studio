<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:backgroundTint="@color/BackgroundCardProduk"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardKecilProduk"
            android:layout_width="100dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="@color/icon"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="@id/stock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/namaProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Produk"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/TeksBawahNavbar"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/cardKecilProduk"
            app:layout_constraintTop_toTopOf="@id/cardKecilProduk"/>

        <TextView
            android:id="@+id/hargaProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/TeksBawahNavbar"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/cardKecilProduk"
            app:layout_constraintTop_toBottomOf="@id/namaProduk"
            android:layout_marginTop="5dp"/>

        <ImageView
            android:id="@+id/category"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/cateory"
            app:tint="@color/IconProduk"
            app:layout_constraintTop_toBottomOf="@id/hargaProduk"
            app:layout_constraintStart_toEndOf="@id/cardKecilProduk"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/jenisProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis Produk"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/TeksBawahNavbar"
            android:textSize="15sp"
            app:layout_constraintStart_toEndOf="@id/category"
            app:layout_constraintTop_toTopOf="@id/category"
            app:layout_constraintBottom_toBottomOf="@id/category"/>

        <ImageView
            android:id="@+id/stock"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/stock"
            app:tint="@color/IconProduk"
            app:layout_constraintTop_toBottomOf="@id/jenisProduk"
            app:layout_constraintStart_toEndOf="@id/cardKecilProduk"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/jumlahProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stock"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/TeksBawahNavbar"
            android:textSize="15sp"
            app:layout_constraintStart_toEndOf="@id/stock"
            app:layout_constraintTop_toTopOf="@id/stock"
            app:layout_constraintBottom_toBottomOf="@id/stock"/>

        <ImageView
            android:id="@+id/cabang"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/cabang"
            app:tint="@color/IconProduk"
            app:layout_constraintTop_toBottomOf="@id/jenisProduk"
            app:layout_constraintStart_toEndOf="@id/jumlahProduk"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/CabangProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cabang"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/TeksBawahNavbar"
            android:textSize="15sp"
            app:layout_constraintStart_toEndOf="@id/cabang"
            app:layout_constraintTop_toTopOf="@id/cabang"
            app:layout_constraintBottom_toBottomOf="@id/cabang"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#000000"
            app:strokeWidth="1.5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <View
                    android:id="@+id/indicatorStatus"
                    android:layout_width="6dp"
                    android:layout_height="5dp"
                    android:background="@drawable/circle_indikator"
                    android:backgroundTint="@color/green_status" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Aktif"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    tools:text="Aktif" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>