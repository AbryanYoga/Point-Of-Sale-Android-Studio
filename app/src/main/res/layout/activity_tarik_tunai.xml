<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgScreen"
    tools:context=".Transaksi.TarikTunaiActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- HEADER SECTION -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/bgCard"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/imageBack"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/back"
                    app:tint="@color/textPrimary" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Tarik Tunai"
                android:textColor="@color/textPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/cardBack"
                app:layout_constraintStart_toEndOf="@id/cardBack"
                app:layout_constraintTop_toTopOf="@id/cardBack" />

            <!-- BALANCE DISPLAY CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/cardBack">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardWalletIcon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:backgroundTint="@color/iconBg"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/imgWalletIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_wallet"
                            app:tint="@color/iconColor" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvLabelSaldo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Saldo Keuntungan"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/cardWalletIcon"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvSaldoSaatIni"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        android:text="Rp 0"
                        android:textColor="@color/textPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/cardWalletIcon"
                        app:layout_constraintTop_toBottomOf="@id/tvLabelSaldo" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- NOMINAL INPUT -->
            <TextView
                android:id="@+id/labelNominal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Nominal Penarikan"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardBalance" />

            <EditText
                android:id="@+id/etNominalPenarikan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext"
                android:backgroundTint="@color/bgCard"
                android:hint="Rp 0"
                android:inputType="phone"
                android:paddingHorizontal="20dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/labelNominal" />

            <!-- METHOD SELECTOR -->
            <TextView
                android:id="@+id/labelMetode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Pilih Metode Penarikan"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etNominalPenarikan" />

            <!-- DOMPET DIGITAL -->
            <TextView
                android:id="@+id/labelDompetDigital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:text="Dompet Digital"
                android:textColor="@color/textHint"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.06"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/labelMetode" />

            <!-- ROW 1: QRIS & GoPay -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQris"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@id/cardGopay"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/labelDompetDigital">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgQris"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/qris"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="QRIS"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgQris"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGopay"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cardQris"
                app:layout_constraintTop_toTopOf="@id/cardQris">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgGopay"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/gopay"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="GoPay"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgGopay"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ROW 2: Dana & OVO -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDana"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@id/cardOvo"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardQris">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgDana"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/dana"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Dana"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgDana"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOvo"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cardDana"
                app:layout_constraintTop_toTopOf="@id/cardDana">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgOvo"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ovo"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="OVO"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgOvo"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ROW 3: ShopeePay -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardShopeePay"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@id/spaceDigital"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardDana">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgShopeepay"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/shopee"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="ShopeePay"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgShopeepay"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:id="@+id/spaceDigital"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="@id/cardShopeePay"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cardShopeePay"
                app:layout_constraintTop_toTopOf="@id/cardShopeePay" />

            <!-- DIVIDER -->
            <View
                android:id="@+id/dividerBank"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:background="@color/strokeCard"
                app:layout_constraintTop_toBottomOf="@id/cardShopeePay" />

            <!-- TRANSFER BANK -->
            <TextView
                android:id="@+id/labelTransferBank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="14dp"
                android:text="Transfer Bank"
                android:textColor="@color/textHint"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.06"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dividerBank" />

            <!-- ROW 4: BRI & BCA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBri"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@id/cardBca"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/labelTransferBank">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgBri"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/bri"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="BRI"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgBri"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBca"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cardBri"
                app:layout_constraintTop_toTopOf="@id/cardBri">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgBca"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/bca"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="BCA"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgBca"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ROW 5: BNI & Mandiri -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBni"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@id/cardMandiri"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardBri">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgBni"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/bni"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="BNI"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgBni"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMandiri"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cardBni"
                app:layout_constraintTop_toTopOf="@id/cardBni">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgMandiri"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/mandiri"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Mandiri"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgMandiri"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ROW 6: CIMB Niaga & BSI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCimb"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@id/cardBsi"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardBni">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgCimb"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/cimb"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="CIMB Niaga"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgCimb"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBsi"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/bgCard"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/strokeCard"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cardCimb"
                app:layout_constraintTop_toTopOf="@id/cardCimb">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/imgBsi"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/bsi"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="BSI"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/imgBsi"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TARGET ACCOUNT INPUT -->
            <TextView
                android:id="@+id/labelNomorTujuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Nomor Rekening / Nomor HP Tujuan"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardCimb" />

            <EditText
                android:id="@+id/etNomorTujuan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext"
                android:backgroundTint="@color/bgCard"
                android:hint="Masukkan nomor rekening atau nomor HP"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/labelNomorTujuan" />

            <!-- PROSES WITHDRAWAL BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProsesPenarikan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/accentPurple"
                android:text="Proses Penarikan"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:layout_constraintTop_toBottomOf="@id/etNomorTujuan" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>