<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:clickable="false"
    android:focusable="false"
    app:cardBackgroundColor="@color/backgroundModKategori"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/CardDalam">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvPenarikanMetodeTujuan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="GoPay - 08123456789"
            android:textColor="@color/textModkategori"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvPenarikanNominal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvPenarikanTanggalWaktu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="26 Mei 2026 09:28"
            android:textColor="#888888"
            android:textSize="11sp"
            app:layout_constraintEnd_toStartOf="@id/tvPenarikanNominal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPenarikanMetodeTujuan" />

        <TextView
            android:id="@+id/tvPenarikanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Berhasil"
            android:textColor="@color/green_status"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPenarikanTanggalWaktu" />

        <TextView
            android:id="@+id/tvPenarikanNominal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-Rp 50.000"
            android:textColor="@color/red_status"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
